# Copy this file to .env and fill in your values
# cp web/backend/.env.example web/backend/.env
#
# Docker / docker-compose users:
#   DATABASE_PATH and PLOTS_PATH are overridden in docker-compose.yml to point
#   at the /data persistent volume. You only need to set the secrets below.

# Database file path (relative to where you run uvicorn; docker-compose overrides this)
DATABASE_PATH=web_app.db

# Secret key for encrypting API keys stored in the database.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace-me-with-a-random-secret

# Secret for JWT tokens (future auth support)
JWT_SECRET=replace-me-with-another-random-secret

# Directory where PV curve PNG plots are saved (docker-compose overrides to /data/plots)
PLOTS_PATH=plots

# Default LLM provider: "openai" or "ollama"
DEFAULT_LLM_PROVIDER=ollama

# Ollama settings (used when DEFAULT_LLM_PROVIDER=ollama)
DEFAULT_OLLAMA_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=llama3.1:8b

# Set to true to enable debug logging
DEBUG=false
